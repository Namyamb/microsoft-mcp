# Copy to `.env` and fill in values.
# Never commit real secrets or personal identifiers to git.

# =========================
# Microsoft / Outlook (Graph)
# =========================
# Azure App Registration (Entra ID) Application (client) ID
OUTLOOK_CLIENT_ID=

# Optional: authority/tenant. Default used by this project:
# https://login.microsoftonline.com/common
OUTLOOK_AUTHORITY=https://login.microsoftonline.com/common

# Optional: default sender mailbox/email address used by some flows
OUTLOOK_SENDER_EMAIL=

# Optional: space-separated delegated scopes.
# Common scopes:
# Mail.Read Mail.ReadWrite Mail.Send User.Read Calendars.Read Calendars.ReadWrite
OUTLOOK_SCOPES=Mail.Read Mail.ReadWrite Mail.Send User.Read Calendars.ReadWrite

# Optional: MSAL token cache file path (relative to repo root by default)
# OUTLOOK_TOKEN_CACHE=.outlook_msal_token_cache.bin

# =========================
# Local LLM (LM Studio)
# =========================
# OpenAI-compatible base URL for LM Studio (or any compatible server)
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# Model name as exposed by your server
LMSTUDIO_MODEL=local-model

# LM Studio typically ignores the key, but the client expects one.
LMSTUDIO_API_KEY=lm-studio

